{
  "name": "codemaster-backend",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "imports": {
    "#contracts/*": "./libs/contracts/src/*",
    "#platform/*": "./libs/platform/src/*",
    "#backend/*": "./apps/backend/src/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build_copy_grammars.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run test/integration --no-file-parallelism",
    "test:magika": "CODEMASTER_TEST_MAGIKA=1 vitest run test/parity/magika_agreement.parity.test.ts",
    "gates": "tsx scripts/gates/run_all.ts",
    "validate-fast": "npm run gates && npm run lint && npm run typecheck && npm run test",
    "migrate:up": "node-pg-migrate up -m migrations -d CODEMASTER_PG_CORE_DSN --no-check-order",
    "migrate:down": "node -e \"console.error('migrate:down is disabled: codemaster migrations are up-only (the squashed baseline is irreversible by design). Recreate a throwaway database and re-run migrate:up. NEVER migrate a shared/cluster DB.'); process.exit(1)\""
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.29.2",
    "@fastify/cookie": "^11.0.2",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.54.0",
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "fastify": "^5.0.0",
    "js-yaml": "^4.1.0",
    "kysely": "^0.27.0",
    "magika": "^1.0.0",
    "node-pg-migrate": "^7.7.0",
    "pg": "^8.13.0",
    "pgvector": "^0.2.0",
    "smol-toml": "^1.6.1",
    "web-tree-sitter": "^0.25.10",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@temporalio/testing": "^1.17.2",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "eslint": "^10.4.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "ts-morph": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^2.1.0"
  }
}
