{
  "name": "codemaster-backend",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "imports": {
    "#contracts/*": "./libs/contracts/src/*",
    "#platform/*": "./libs/platform/src/*",
    "#backend/*": "./apps/backend/src/backend/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run test/integration",
    "test:magika": "CODEMASTER_TEST_MAGIKA=1 vitest run test/parity/magika_agreement.parity.test.ts",
    "gates": "tsx scripts/gates/run_all.ts",
    "validate-fast": "npm run gates && npm run lint && npm run typecheck && npm run test",
    "migrate:up": "node-pg-migrate up -m migrations -d CODEMASTER_PG_CORE_DSN --no-check-order",
    "migrate:down": "node-pg-migrate down -m migrations -d CODEMASTER_PG_CORE_DSN --no-check-order"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.12.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.54.0",
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "fastify": "^5.0.0",
    "js-yaml": "^4.1.0",
    "kysely": "^0.27.0",
    "magika": "^1.0.0",
    "node-pg-migrate": "^7.7.0",
    "pg": "^8.13.0",
    "pgvector": "^0.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "eslint": "^10.4.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "ts-morph": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^2.1.0"
  }
}
