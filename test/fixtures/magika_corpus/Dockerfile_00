# codemaster — single image used by all 8 deployments via --mode flag.
#
# Multi-stage build:
#   1. uv-builder:  resolves and installs deps into a venv
#   2. runtime:     copies the venv + source into a distroless-style runtime
#
# Pinned per pyproject.toml + uv.lock; fails build if uv.lock drifts.

# ──────────────────────────────────────────────────────────────────────────────
# Stage 1 — uv-builder
# ──────────────────────────────────────────────────────────────────────────────
FROM nexus.acme.com/codemaster/python:3.13-slim AS uv-builder

# Install uv (Astral) — pinned by digest in production CI.
COPY --from=ghcr.io/astral-sh/uv:0.5 /uv /usr/local/bin/uv

WORKDIR /app

# Cache layer: copy lockfiles + README first. README.md is
# referenced by pyproject.toml's `readme = "README.md"`; hatchling
# validates its existence during the editable build below.
COPY pyproject.toml uv.lock README.md ./

# Install dependencies into a venv at /app/.venv. --frozen ensures we use
# the lockfile exactly; `uv sync --check` would refuse drift.
RUN uv sync --frozen --no-dev --no-install-project

# Now copy the project source and install it editable into the venv.
COPY codemaster/ ./codemaster/
COPY contracts/ ./contracts/
RUN uv sync --frozen --no-dev

# ──────────────────────────────────────────────────────────────────────────────
# Stage 2 — runtime
# ──────────────────────────────────────────────────────────────────────────────
FROM nexus.acme.com/codemaster/python:3.13-slim AS runtime

# Tier 1 deterministic-analyzer binaries (Phase A — static-analysis
# coverage gap fix, 2026-05-16). These are the in-worker subprocess
# linters: Ruff (Python), Gitleaks (secrets), ESLint (JS/TS).
# Semgrep and Trivy run as K8s Jobs (Phase C) — they don't need
# binaries in this image.
#
# Versions are pinned for reproducibility. Update by changing the
# version vars below + re-build; the version-verify lines at the
# end of the RUN block catch any silent registry-side regression.

ARG RUFF_VERSION=0.6.9
ARG GITLEAKS_VERSION=8.18.4
ARG ESLINT_VERSION=9.10.0

# S19.SMOKE.7 — `git` is required at runtime by the review-pipeline
# clone activities (GitSubprocessCloner shells out to `git clone`).
# Without it the activity fails with [Errno 2]. python:3.13-slim
# omits git by default; install minimally and clean apt lists in
# the same RUN to keep the layer small.
#
# Phase A (2026-05-16): also install curl + ca-certificates + gnupg
# (gitleaks tarball download) and Node.js (eslint via npm).
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        git \
        curl \
        ca-certificates \
        gnupg \
 && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
 && apt-get install -y --no-install-recommends nodejs \
 && rm -rf /var/lib/apt/lists/*

# Install ruff via pip in the venv (uv-managed Python env).
RUN uv pip install --no-cache "ruff==${RUFF_VERSION}" \
 && ruff --version

# Install gitleaks via release tarball — pinned version, integrity-verified
# via the upstream release's checksum (not validated here for v0; future
# follow-up to add SHA verify when a registry is stood up).
RUN curl -fsSL \
        "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz" \
        -o /tmp/gitleaks.tar.gz \
 && tar -xzf /tmp/gitleaks.tar.gz -C /usr/local/bin gitleaks \
 && rm /tmp/gitleaks.tar.gz \
 && chmod +x /usr/local/bin/gitleaks \
 && gitleaks version

# Install eslint globally via npm.
RUN npm install -g "eslint@${ESLINT_VERSION}" \
 && eslint --version

# Non-root uid 1001 matches the Helm container.securityContext.
RUN groupadd --gid 1001 codemaster \
 && useradd --uid 1001 --gid 1001 --shell /sbin/nologin --create-home codemaster

WORKDIR /app

# Copy the resolved venv + source from the builder.
COPY --from=uv-builder --chown=codemaster:codemaster /app /app

# Add the venv bin to PATH so `codemaster` and `uv run python ...` resolve.
ENV PATH="/app/.venv/bin:${PATH}" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONHASHSEED=random

USER 1001

# Default to the api mode; Helm overrides via container args ['--mode', 'api'|'worker'|...].
ENTRYPOINT ["python", "-m", "codemaster.cli.main"]
CMD ["--mode", "api"]
