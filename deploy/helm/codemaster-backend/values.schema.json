{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "codemaster-backend Helm values",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "commonLabels": { "type": "object" },
    "commonAnnotations": { "type": "object" },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "rollOnConfigChange": { "type": "boolean" },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "preStopSleepSeconds": { "type": "integer", "minimum": 0 },
    "minReadySeconds": { "type": "integer", "minimum": 0 },
    "priorityClassName": { "type": "string" },
    "image": {
      "type": "object",
      "required": ["repository", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "pullSecrets": { "type": "array", "items": { "type": "object" } }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": { "create": { "type": "boolean" } }
    },
    "podSecurityContext": { "type": "object" },
    "containerSecurityContext": { "type": "object" },
    "resources": { "type": "object" },
    "scratch": {
      "type": "object",
      "properties": {
        "workspace": { "$ref": "#/definitions/scratchVolume" },
        "cloneCache": { "$ref": "#/definitions/scratchVolume" },
        "tmp": { "$ref": "#/definitions/scratchVolume" }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "annotations": { "type": "object" }
      }
    },
    "ports": {
      "type": "object",
      "properties": { "http": { "type": "integer", "minimum": 1, "maximum": 65535 } }
    },
    "probes": { "type": "object" },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 0, "maximum": 100 },
        "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 0, "maximum": 100 },
        "behavior": { "type": "object" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array" },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    },
    "migrate": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "hookWeight": { "type": ["integer", "string"] },
        "hookDeletePolicy": { "type": "string" },
        "resources": { "type": "object" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "nodeEnv": { "type": "string" },
        "nodeMaxOldSpaceSizeMb": { "type": "integer", "minimum": 0 },
        "api": { "type": "object" },
        "runtime": {
          "type": "object",
          "properties": {
            "mode": { "type": "string", "enum": ["postgres", "shadow"] }
          },
          "required": ["mode"]
        },
        "embeddings": {
          "type": "object",
          "properties": {
            "provider": { "type": "string", "enum": ["platform", "openai_compat"] }
          }
        },
        "workspaceRoot": { "type": "string", "minLength": 1 },
        "cloneCacheRoot": { "type": "string", "minLength": 1 },
        "features": { "type": "object" },
        "langfuse": { "type": "object" },
        "extra": { "type": "object" }
      }
    },
    "extraEnv": { "type": "array" },
    "extraEnvFrom": { "type": "array" },
    "extraVolumes": { "type": "array" },
    "extraVolumeMounts": { "type": "array" },
    "tests": { "type": "object" },
    "vault": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["agent", "token", "external"] },
        "addr": { "type": "string" },
        "secretsDir": { "type": "string", "minLength": 1 },
        "tokenPath": { "type": "string" },
        "agent": {
          "type": "object",
          "properties": {
            "role": { "type": "string" },
            "fileSecrets": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["file", "path"],
                "properties": {
                  "file": { "type": "string", "pattern": "^[A-Za-z0-9_]+$" },
                  "path": { "type": "string", "minLength": 1 }
                }
              }
            },
            "envSecrets": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["env", "path", "key"],
                "properties": {
                  "env": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
                  "path": { "type": "string", "minLength": 1 },
                  "key": { "type": "string", "minLength": 1 }
                }
              }
            },
            "extraAnnotations": { "type": "object" }
          }
        },
        "token": { "type": "object" }
      }
    }
  },
  "definitions": {
    "scratchVolume": {
      "type": "object",
      "properties": {
        "sizeLimit": { "type": "string" },
        "medium": { "type": "string", "enum": ["", "Memory"] }
      }
    }
  }
}
