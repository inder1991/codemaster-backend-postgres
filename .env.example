# codemaster-backend — LOCAL dev env for a Mac.  Copy to `.env` and edit.
#
# NOTE: the app does NOT auto-load .env (no dotenv). Load it explicitly:
#   one-time per shell:   set -a; source .env; set +a
#   then run migrate + the app (see README-LOCAL section below).
# Or run directly with Node's flag:
#   node --env-file=.env --import tsx apps/backend/src/main.ts
#
# This file is the MINIMAL boot (HTTP API + worker up, NO Vault needed). The
# "REAL PR REVIEW" block at the bottom adds what an actual webhook→review needs.

# ── Postgres (disposable local DB; MUST have pgvector + pg_partman → use the
#    codemaster-postgres:dev image, not stock postgres). Run `npm run migrate:up` once. ──
CODEMASTER_PG_CORE_DSN=postgresql://postgres:devpass@localhost:5434/postgres

# ── Temporal (local `temporal server start-dev`) ──
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
# This single process is BOTH the producer and the review worker. Pin ONE queue
# so they agree — if unset, producer→"review-default" but worker→"review-pull-request-dualrun"
# (mismatch ⇒ zero reviews processed).
TEMPORAL_TASK_QUEUE=review-default
# Leave NODE_ENV unset for dev loopback defaults. (Setting it to "production"
# forces you to set TEMPORAL_NAMESPACE + TEMPORAL_TASK_QUEUE explicitly.)

# ── HTTP API ──
CODEMASTER_API_HOST=0.0.0.0
CODEMASTER_API_PORT=8080
CODEMASTER_SECURE_COOKIES=false

# ── Embedder: stub = no external service (lightest, deterministic). ──
CODEMASTER_EMBEDDINGS_PROVIDER=platform
CODEMASTER_QWEN_DSN=stub://recording

# ── Writable scratch. The Linux defaults (/var/lib/codemaster/workspaces, /clone-cache)
#    are NOT writable on a Mac — point them at your home. `mkdir -p` these first. ──
CODEMASTER_WORKSPACE_ROOT=/Users/ascoe/.codemaster/workspaces
CODEMASTER_CLONE_CACHE_ROOT=/Users/ascoe/.codemaster/clone-cache

# ── Auth/admin routes OFF ⇒ NO Vault required to boot. Flip to true only with a
#    seeded Vault (it eagerly loads field-encryption + auth secrets at startup). ──
CODEMASTER_AUTH_ROUTES_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════════
# FOR A REAL PR REVIEW (GitHub webhook → review → comment) you also need a dev Vault
# and a GitHub App. Run a dev Vault:
#   vault server -dev -dev-root-token-id=devroot -dev-listen-address=0.0.0.0:8200
# Seed the KV paths (see deploy/local-kind/seed-vault.sh for the exact shapes):
#   secret/codemaster/github/app          (app_id, private_key_pem, webhook_secret)
#   secret/codemaster/llm/anthropic       (api_key)            ← the review LLM
#   secret/codemaster/field-encryption/keys ({current_version, keys:{v1:<b64-32B>}})
#   secret/codemaster/api/auth            (session_signing_key, csrf_secret)  ← only if auth routes on
# then uncomment:
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=devroot
# CODEMASTER_VAULT_SECRET_SOURCE=vault-api
# ═══════════════════════════════════════════════════════════════════════════════

# ── (Optional) real embeddings via local Ollama instead of the stub ──
# CODEMASTER_EMBEDDINGS_PROVIDER=openai_compat
# CODEMASTER_EMBEDDER_BASE_URL=http://localhost:11434
# CODEMASTER_EMBEDDER_MODEL_NAME=mxbai-embed-large
# CODEMASTER_EMBEDDER_API_KEY=ollama
